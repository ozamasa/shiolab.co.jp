---
const { title = "LOGICLAB", description = "", canonical = undefined } = Astro.props;
import "../styles/global.css";
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>{title}</title>
    {description ? <meta name="description" content={description} /> : null}
    {canonical ? <link rel="canonical" href={canonical} /> : null}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-6767052617363894" crossorigin="anonymous"></script>
  </head>
  <body>
    <header class="siteHeader">
      <div class="headerTopBar"></div>
      <div class="headerInner shell">
        <a href="/" class="headerBrand" aria-label="LOGICLAB トップへ">
          <span class="logo">LOG</span>
          <span class="siteTitle">LOGICLAB</span>
        </a>

        <nav class="mainNav" aria-label="グローバルナビゲーション">
          <a href="/articles/">攻略パターン</a>
          <a href="/roadmap/">ロードマップ</a>
          <a href="/about/">このサイトについて</a>
        </nav>
      </div>
    </header>

    <main class="wrap">
      <slot />
    </main>

    <footer class="footer">
      <div class="footerInner shell">
        <div>
          <div class="footerDesc">4択問題を「切り方」で整理する学習サイト</div>
          <div class="footerCopy">© {new Date().getFullYear()} LOGICLAB</div>
        </div>
        <div class="footerLinks">
          <a href="/privacy/">プライバシーポリシー</a>
          <a href="/terms/">利用規約</a>
          <a href="/disclaimer/">免責事項</a>
        </div>
      </div>
      <div class="footerNote shell">このサイトは英語学習の情報提供を目的として運営されています。</div>
    </footer>
  </body>
</html>