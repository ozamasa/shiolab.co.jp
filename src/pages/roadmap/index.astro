---
import BaseLayout from "../../layouts/BaseLayout.astro";

const steps = [
  { step: "STEP1", title: "現在完了形", href: "/articles/m0i58z__8l7b/" },
  { step: "STEP2", title: "受動態", href: "/articles/xlauatc7h3u/" },
  { step: "STEP3", title: "関係代名詞", href: "/articles/h3t2_3dhkzl/" },
  { step: "STEP4", title: "不定詞", href: "/articles/tdjrcvrf1b-a/" },
  { step: "STEP5", title: "比較", href: "/articles/4_o_go8w1/" },
  { step: "STEP6", title: "助動詞", href: "/articles/bbv2iufy9/" },
  { step: "STEP7", title: "受動態の疑問文", href: "/articles/j1t5n4kq77m/" },
  { step: "STEP8", title: "分詞", href: "/articles/45bmjvget/" },
  { step: "STEP9", title: "間接疑問文", href: "/articles/yxhe1x9og/" },
  { step: "STEP10", title: "接続詞と前置詞", href: "/articles/3riztgotej/" },
  { step: "STEP11", title: "代名詞", href: "/articles/7uxn97h7o/" },
  { step: "STEP12", title: "形容詞と副詞", href: "/articles/buck2wkbjvz/" },
  { step: "STEP13", title: "最上級", href: "/articles/3ci5pwb78f5/" },
  { step: "STEP14", title: "There is / There are", href: "/articles/9ojgxas6cb48/" },
  { step: "STEP15", title: "命令文", href: "/articles/38_cic-41p/" },
];
---
<BaseLayout
  title="英検3級文法を最短で理解するロードマップ｜LOGICLAB"
  description="英検初級レベルの英文法を構造から理解するための15ステップの学習ロードマップです。"
>
  <section class="hero">
    <div class="heroInner">
      <h1>英検3級文法を最短で理解するロードマップ</h1>
      <p class="lead">英語の文法は、単語やルールを個別に覚えるだけではなかなか理解が定着しません。</p>
      <p class="lead">このサイトでは、英文を「意味のかたまり」に分けて理解する独自の方法「切断術」をベースに、英検3級レベルの英文法を体系的に解説しています。</p>
    </div>
  </section>

  <section class="section">
    <div class="grid">
      {steps.map((item) => (
        <a class="card cardHover" href={item.href} style="color:inherit; text-decoration:none;">
          <div class="kicker" style="margin-bottom:10px;">{item.step}</div>
          <h2 class="cardTitle" style="margin:0;">{item.title}</h2>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>