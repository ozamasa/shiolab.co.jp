---
import BaseLayout from "../layouts/BaseLayout.astro";
import { fetchAllArticles, getRoadmapGroups, normalizeCategories } from "../lib/microcms";

const articles = await fetchAllArticles();

articles.sort((a, b) => {
  const ad = new Date(a.date || a.publishedAt || a.createdAt || 0).getTime();
  const bd = new Date(b.date || b.publishedAt || b.createdAt || 0).getTime();
  return bd - ad;
});

const latest = articles.slice(0, 4);
const { basic } = getRoadmapGroups(articles);
const roadmapTop = basic.slice(0, 15);
const dateLabel = (a: any) => a.date || a.publishedAt || a.createdAt || "";
---

<BaseLayout
  title="LOGICLAB｜英検3級英文法の攻略パターン集"
  description="英検初級レベルの英文法問題を、『なぜその選択肢は切れるのか』の視点で整理する学習サイト。"
>
  <section class="hero">
    <div class="heroInner">
      <p class="kicker">4択問題の「切り方」を学ぶ</p>
      <h1>LOGICLAB</h1>
      <p class="lead">
        英検初級レベルの英文法問題を、「なぜその選択肢は切れるのか」という視点で整理する学習サイトです。
      </p>
      <p class="lead">
        正解を覚えるのではなく、文法や文構造から不正解を見抜く考え方を身につけることを目的としています。
      </p>
      <div class="heroCta">
        <a class="btn" href="/roadmap/">ロードマップを見る</a>
      </div>
    </div>
  </section>

  <section class="section sectionPrimary">
    <div class="sectionHeader">
      <div>
        <h2>英検初級レベル学習ロードマップ</h2>
        <p>15本の記事を順番に読むための入口です</p>
      </div>
      <a class="btn btnSmall" href="/roadmap/">ロードマップを見る</a>
    </div>

    <div class="card roadmapCard">
      <p class="roadmapLead">
        英検初級レベルの文法を、構造から順番に理解するためのガイドです。単発で記事を読むよりも、流れに沿って読むほうが理解しやすくなります。
      </p>

      <div class="roadmapMiniGrid">
        {roadmapTop.map((item) => (
          <a class="roadmapStep" href={`/articles/${item.id}/`}>
            {item.roadmapLabel || item.title}
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="sectionHeader">
      <div>
        <h2>最新の攻略パターン</h2>
        <p>最近追加された記事を新しい順に掲載しています</p>
      </div>
      <a class="btn btnSmall" href="/articles/">すべての記事</a>
    </div>

    {latest.length === 0 ? (
      <section class="card">
        <p>まだ記事がありません。最初の記事を追加するとここに表示されます。</p>
      </section>
    ) : (
      <section class="grid">
        {latest.map((a) => (
          <article class="card cardHover">
            <h3 class="articleCardTitle">
              <a class="cardLink" href={`/articles/${a.id}/`}>{a.title}</a>
            </h3>

            {a.description ? <p class="articleDesc">{a.description}</p> : null}

            <div class="metaRow" style="margin-top:0;">
              {a.category ? (
                <span class="metaItem">
                  カテゴリ：
                  {normalizeCategories(a.category).map((c) => (
                    <a href={`/category/${c.slug}/`} class="tag">{c.label}</a>
                  ))}
                </span>
              ) : (
                <span class="metaItem">カテゴリ：未設定</span>
              )}
              {dateLabel(a) ? <span class="metaItem">更新：{String(dateLabel(a)).slice(0, 10)}</span> : null}
            </div>

            <div style="margin-top:14px;">
              <a class="btn btnSmall" href={`/articles/${a.id}/`}>続きを読む</a>
            </div>
          </article>
        ))}
      </section>
    )}
  </section>

  <section class="section">
    <div class="card prose">
      <h2>このサイトの考え方</h2>
      <p>
        LOGICLABは、英検初級レベルの4択問題を「なぜその選択肢は切れるのか」という視点で整理する学習サイトです。
      </p>
      <p>
        正解を暗記するのではなく、文法や文構造から不正解を見抜く考え方を身につけることを目的としています。
      </p>
    </div>
  </section>

  <section class="section">
    <div class="sectionHeader">
      <div>
        <h2>使い方</h2>
        <p>最短で「切り方」を身につける流れ</p>
      </div>
      <a class="btn btnSmall" href="/roadmap/">ロードマップへ</a>
    </div>

    <section class="card">
      <ol class="steps">
        <li>ロードマップから、順番にテーマを選ぶ</li>
        <li>「切り方」を読んで、型をつかむ</li>
        <li>必要に応じてクイズで確認し、定着させる</li>
      </ol>
    </section>
  </section>
</BaseLayout>