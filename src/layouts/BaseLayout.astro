---
const { title = "LOGICLAB", description = "", canonical = undefined } = Astro.props;
import "../styles/global.css";
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>{title}</title>
    {description ? <meta name="description" content={description} /> : null}
    {canonical ? <link rel="canonical" href={canonical} /> : null}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-6767052617363894"
         crossorigin="anonymous"></script>
  </head>
  <body>
    <header class="siteHeader">
      <div class="headerInner">
        <a href="/" class="logo">LOGICLAB</a>
        <nav class="mainNav">
          <a href="/roadmap/">ロードマップ</a>
          <a href="/articles/">最新記事</a>
          <a href="/guide/">学習ガイド</a>
        </nav>
      </div>
    </header>

    <main class="wrap">
      <slot />
    </main>

    <footer class="footer">
      <div class="footerInner">
        <div>
          4択問題を「切り方」で整理する学習サイト
          © 2026 LOGICLAB
        </div>

        <div class="footerLinks">
          <a href="/privacy/">プライバシーポリシー</a>
          <a href="/terms/">利用規約</a>
          <a href="/about/">免責事項</a>
        </div>
      </div>
    </footer>
  </body>
</html>
