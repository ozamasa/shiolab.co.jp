---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { fetchAllArticles } from "../../lib/microcms";

const articles = await fetchAllArticles();

const basic = articles
  .filter((a) => a.roadmapType === "basic")
  .sort((a, b) => (a.roadmapOrder || 999) - (b.roadmapOrder || 999));

const advanced = articles
  .filter((a) => a.roadmapType === "advanced")
  .sort((a, b) => {
    const ad = new Date(a.date || a.publishedAt || a.createdAt || 0).getTime();
    const bd = new Date(b.date || b.publishedAt || b.createdAt || 0).getTime();
    return bd - ad;
  });
---

<BaseLayout
  title="英検3級文法を最短で理解するロードマップ｜LOGICLAB"
  description="英検初級レベルの英文法を構造から理解するための学習ロードマップです。"
>
  <section class="hero">
    <div class="heroInner">
      <h1>英検3級文法を最短で理解するロードマップ</h1>
      <p class="lead">
        英検初級レベルの文法を、基礎から順番に理解するための学習ガイドです。
      </p>
    </div>
  </section>

  {basic.length > 0 ? (
    <section class="section">
      <div class="sectionHeader">
        <div>
          <h2>基礎15ステップ</h2>
          <p>まずはここから順番に読むのがおすすめです</p>
        </div>
      </div>

      <div class="grid">
        {basic.map((item, i) => (
          <a class="card cardHover" href={`/articles/${item.id}/`} style="color:inherit; text-decoration:none;">
            <div class="kicker" style="margin-bottom:10px;">STEP{i + 1}</div>
            <h2 class="cardTitle" style="margin:0;">{item.roadmapLabel || item.title}</h2>
          </a>
        ))}
      </div>
    </section>
  ) : null}

  {advanced.length > 0 ? (
    <section class="section">
      <div class="sectionHeader">
        <div>
          <h2>発展記事</h2>
          <p>基礎を読んだあとに取り組みたいテーマです</p>
        </div>
      </div>

      <div class="grid">
        {advanced.map((item) => (
          <article class="card cardHover">
            <h3 class="articleCardTitle">
              <a class="cardLink" href={`/articles/${item.id}/`}>{item.title}</a>
            </h3>
            {item.description ? <p class="articleDesc">{item.description}</p> : null}
          </article>
        ))}
      </div>
    </section>
  ) : null}

  {basic.length === 0 && advanced.length === 0 ? (
    <section class="section">
      <div class="card">
        <p style="margin:0;">ロードマップに表示する記事がまだありません。</p>
      </div>
    </section>
  ) : null}
</BaseLayout>